<%- layout("/layouts/boilerplate.ejs") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">
            <br><br>
            <h1>Add New Stay</h1><br>
            
            <form action="/hotels" method="post" novalidate class="needs-validation">
                <div class="mb-2">
                    <label for="title" class="form-label">Title</label><br>
                    <input  name="hotel[title]" type="text" placeholder="Title of your hotel" id="title" class="form-control" required>
                </div>


                <div class="mb-2">
                    <label for="description" class="form-label">About your Stay</label><br>
                    <textarea name="hotel[description]" type="text" placeholder="About your hotel" id="description" class="form-control" required rows="5"></textarea>
                </div>


                <div class="mb-2">
                    <label for="image" class="form-label">Image Url.</label><br>
                    <input name="hotel[image]" type="text" placeholder="Type the image-url of your Hotel" id="image" class="form-control">
                </div>


                <div class="row">
                    <div class="mb-2 col-md-5">
                        <label for="price" class="form-label">Price</label><br>
                        <input name="hotel[price]" type="text" placeholder="&#8377; 2,000" id="price" class="form-control" required>
                    </div>
                    <div class="mb-2 col-md-7">
                        <label for="country" class="form-label">Country</label><br>
                        <input  name="hotel[country]" type="text" placeholder="India" id="country" class="form-control" required>
                    </div>
                </div>

                <div class="mb-2">
                    <label for="location" class="form-label">Location</label><br>
                    <input name="hotel[location]" type="text" placeholder="Espalned, Kolkata" id="location" class="form-control" required>
                </div>

                <button type="submit" class="btn btn-dark new-btn mb-4">add your hotel</button>
            </form>
        </div>
    </div>
