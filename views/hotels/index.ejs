<%- layout("/layouts/boilerplate.ejs") %>
  <div class="all-hotels">
    <h3 class="mb-5 mt-5">All Stays</h3>
  </div>
  <div class="main">
    <%for(let hotel of allhotels){%>
      <div class="step-listing ">
        <a href="/hotels/<%= hotel._id %>" class="main-page-list">
          <div class=" hotels">
            <div class="card-img">
              <img src="<%= hotel.image%>" class="card-img-top" alt="<%= hotel.title %>'s images">
            </div>
            <div class="card-body" style="margin-left: 0.5rem;">
              <div class="title-hotel">
                <p class="card-text"><%= hotel.title %></p>
              </div>
              <div class="price-hotel">
                <p class="card-text">&#8377; <%= hotel.price.toLocaleString('un-IN') %></p>
              </div>
            </div>
          </div>
        </a>
      </div>
    <%}%>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>